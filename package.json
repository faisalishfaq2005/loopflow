{
  "name": "@loopflow/cli",
  "version": "0.1.0",
  "description": "Design loops that prompt your coding agent — recursive goals for Claude Code with verification gates, budgets, memory, and worktree isolation.",
  "keywords": [
    "claude",
    "claude-code",
    "ai-agents",
    "loop-engineering",
    "automation",
    "orchestration",
    "cli"
  ],
  "author": "Muhammad Faisal Ishfaq",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faisalishfaq2005/loopflow.git"
  },
  "homepage": "https://github.com/faisalishfaq2005/loopflow#readme",
  "bugs": {
    "url": "https://github.com/faisalishfaq2005/loopflow/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "loopflow": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "cross-spawn": "^7.0.6",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
